{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://yoon-wi.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://yoon-wi.onrender.com/socket.io/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
